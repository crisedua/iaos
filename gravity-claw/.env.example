# Gravity Claw — Environment Variables
# Copy this to .env and fill in values.

# ── Core ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=       # Use service key for agent (not anon key)

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=    # any random string for webhook security
ALLOWED_TELEGRAM_USER_IDS=  # comma-separated Telegram user IDs allowed to chat

# ── Freedcamp ─────────────────────────────────────────────────
FREEDCAMP_API_KEY=
FREEDCAMP_USER_ID=

# ── OpenRouter (optional — for model routing when ready) ───────
# OPENROUTER_API_KEY=

# ── Agent Config ──────────────────────────────────────────────
PORT=3000
WORKSPACE_PATH=/app          # On Railway; locally: C:\ClaudeCode
